<Window x:Class="dog.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:dog"
        mc:Ignorable="d"
        ResizeMode="NoResize"
        KeyDown="OnKeyDown"
        Title="The Dog" Height="700" Width="700">

    <!--ClassStyles-->
    <Window.Resources>

        <!--Remove standart button style-->
        <Style x:Key="noStaBtnStyle" TargetType="Button">
            <Setter Property="Template">
                <Setter.Value>
                    <!--Border-->
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}">
                            <ContentPresenter 
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>

                </Setter.Value>

            </Setter>
        </Style>
    </Window.Resources>


    <Grid Margin="0,6,0,-6">
        <!--GameGird (created in c#)-->
        <Grid x:Name="GameGrid"/>



        <!--MenuGrid-->
        <Grid x:Name="MenuGrid" Background="#90000000" Visibility="Visible">

            <!--**********Menu**********-->
            <Grid Height="564" Width="364" x:Name="Menu" Visibility="Visible">
                <!--RowDefinitions-->
                <Grid.RowDefinitions>
                    <RowDefinition Height="5*" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>


                <!--Banner&Stats-->
                <Border Grid.Row="0" CornerRadius="20" Margin="10">
                    <Border.Background>
                        <ImageBrush ImageSource="assets/img/banner.png" Stretch="Fill"/>
                    </Border.Background>


                    <!--Stats-->
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>


                        <!--bones-->
                        <StackPanel Grid.Column="0">
                            <Image 
                                Source="/assets/img/bone.png" 
                                Height="128"/>
                            
                            <TextBlock 
                                x:Name="PointsText"
                                Text="0" 
                                TextAlignment="Center" 
                                FontSize="24"
                                Foreground="White"
                                FontWeight="DemiBold"/>
                        </StackPanel>

                        
                        <!--highscore-->
                        <StackPanel Grid.Column="1">
                            <Image 
                                Source="/assets/img/trophe.png" 
                                Height="128"/>

                            <TextBlock 
                                Text="soon" 
                                TextAlignment="Center" 
                                FontSize="24"
                                Foreground="White"
                                FontWeight="DemiBold"/>
                        </StackPanel>
                    </Grid>
                </Border>


                <!--PlayButton-->
                <Border Grid.Row="1" CornerRadius="10" Margin="10" Background="Blue">
                    <!--Button-->
                    <Button Style="{StaticResource noStaBtnStyle}"
                            Foreground="White" 
                            Background="Transparent" 
                            BorderThickness="0" 
                            Cursor="Hand"  
                            Click="startGameloop">

                        <Grid Width="364">
                            <!--ColumnDefinitions-->
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="1*"/>
                                <ColumnDefinition Width="4*"/>
                            </Grid.ColumnDefinitions>

                            <!--Icon-->
                            <Border Grid.Column="0" HorizontalAlignment="Center">
                                <Image Source="assets/icons/play.png" Height="30"/>
                            </Border>

                            <!--Text-->
                            <Border Grid.Column="1">
                                <TextBlock Text="Spielen" 
                                           TextAlignment="Center" 
                                           FontSize="22" 
                                           FontWeight="DemiBold" 
                                           Foreground="White" 
                                           Background="Transparent" 
                                           Margin="-70,0,27,0"/>
                            </Border>
                        </Grid>
                    </Button>

                </Border>


                <!--SettingsButton-->
                <Border Grid.Row="2" 
                        CornerRadius="10" 
                        Margin="10" 
                        Background="Blue" 
                        BorderThickness="0">

                    <!--Button-->
                    <Button Click="changeSettings" 
                            Style="{StaticResource noStaBtnStyle}" 
                            Foreground="White" 
                            BorderThickness="0" 
                            Cursor="Hand" 
                            Background="Transparent">

                        <Grid Width="364">
                            <!--ColumnDefinitions-->
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="1*"/>
                                <ColumnDefinition Width="4*"/>
                            </Grid.ColumnDefinitions>

                            <!--Icon-->
                            <Border Grid.Column="0" HorizontalAlignment="Center">
                                <Image Source="assets/icons/settings.png" Height="30"/>
                            </Border>

                            <!--Text-->
                            <Border Grid.Column="1">
                                <TextBlock Text="Einstellungen" 
                                           TextAlignment="Center" 
                                           FontSize="22" 
                                           FontWeight="DemiBold" 
                                           Foreground="White" 
                                           Background="Transparent" 
                                           Margin="-70,0,27,0"/>
                            </Border>
                        </Grid>
                    </Button>

                </Border>


            </Grid>


            <!--**********Settings**********-->
            <Grid Height="564" Width="364" x:Name="SettingsGrid" Visibility="Collapsed">
                <!--RowDefinitions-->
                <Grid.RowDefinitions>
                    <RowDefinition Height="*" />
                    <RowDefinition Height="auto" />
                    <RowDefinition Height="auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>


                <!--*****title*****-->
                <Border Grid.Row="0" CornerRadius="20">
                    <Grid>
                        <!--ColumnDefinitions-->
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="1*"/>
                            <ColumnDefinition Width="4*"/>
                        </Grid.ColumnDefinitions>

                        <!--Back Button-->
                        <Border Grid.Column="0"  
                                HorizontalAlignment="Center" 
                                Background="Blue" 
                                Height="40" 
                                Width="40" 
                                CornerRadius="6">

                            <!--Button-->
                            <Button Click="changeSettings" 
                                    Grid.Column="0" Style="{StaticResource noStaBtnStyle}" 
                                    HorizontalAlignment="Center" 
                                    VerticalAlignment="Center" 
                                    BorderThickness="0" 
                                    Cursor="Hand" 
                                    Background="Transparent">

                                <!--Icon-->
                                <Image Source="assets/icons/arrow_back.png" Height="30"/>
                            </Button>
                        </Border>

                        <!--Text-->
                        <TextBlock Grid.Column="1" 
                                   Text="Einstellungen" 
                                   FontSize="26" 
                                   FontWeight="DemiBold" 
                                   Foreground="White" 
                                   Background="Transparent" 
                                   VerticalAlignment="Center"/>
                    </Grid>
                </Border>

                <!--*****Speed*****-->
                <Border Grid.Row="1" 
                        Margin="10,6,10,6" 
                        CornerRadius="10" 
                        Background="#12FFFFFF" 
                        BorderBrush="#30FFFFFF" 
                        BorderThickness="0.5">

                    <!--Stack-->
                    <StackPanel Margin="16,10,16,10">
                        <!--title-->
                        <TextBlock Text="Geschwindigkeit(SPS):" 
                                   FontSize="16" 
                                   FontWeight="Bold" 
                                   Foreground="White" 
                                   Margin="0,0,0,8"/>


                        <!--Slider-->
                        <Slider x:Name="intervalSlider" 
                                Minimum="3" 
                                Maximum="15" 
                                Value="5" 
                                TickFrequency="1" 
                                IsSnapToTickEnabled="True" 
                                ValueChanged="Speed_interval" 
                                Height="22">
                            <!--Custom Sliderstyle-->
                            <Slider.Template>
                                <ControlTemplate TargetType="Slider">
                                    <Grid>
                                        <Track x:Name="PART_Track">
                                            <!--SliderBeforeBG-->
                                            <Track.DecreaseRepeatButton>
                                                <RepeatButton Command="Slider.DecreaseLarge">
                                                    <RepeatButton.Template>
                                                        <ControlTemplate>
                                                            <Border Background="#FF0000FF" CornerRadius="99" Height="5"/>
                                                        </ControlTemplate>
                                                    </RepeatButton.Template>
                                                </RepeatButton>
                                            </Track.DecreaseRepeatButton>

                                            <!--Indicator-->
                                            <Track.Thumb>
                                                <Thumb>
                                                    <Thumb.Template>
                                                        <ControlTemplate>
                                                            <Ellipse Width="16" Height="16"
                                                                     Fill="#FF0000FF"
                                                                     Stroke="White"
                                                                     StrokeThickness="2.5"/>
                                                        </ControlTemplate>
                                                    </Thumb.Template>
                                                </Thumb>
                                            </Track.Thumb>

                                            <!--SliderAfterBG-->
                                            <Track.IncreaseRepeatButton>
                                                <RepeatButton Command="Slider.IncreaseLarge">
                                                    <RepeatButton.Template>
                                                        <ControlTemplate>
                                                            <Border Background="#30FFFFFF" CornerRadius="99" Height="5"/>
                                                        </ControlTemplate>
                                                    </RepeatButton.Template>
                                                </RepeatButton>
                                            </Track.IncreaseRepeatButton>

                                        </Track>
                                    </Grid>
                                </ControlTemplate>
                            </Slider.Template>
                        </Slider>


                        <!--MinMaxIndicator-->
                        <Grid Margin="0,6,0,0">
                            <!--ColumnDefinitions-->
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition/>
                                <ColumnDefinition/>
                                <ColumnDefinition/>
                            </Grid.ColumnDefinitions>

                            <!--Min(3)-->
                            <TextBlock Text="3" 
                                       Grid.Column="0" 
                                       FontSize="11"
                                       Foreground="#80FFFFFF" 
                                       HorizontalAlignment="Left"/>

                            <!--Indicator-->
                            <TextBlock Text="{Binding ElementName=intervalSlider, Path=Value}"
                                       Grid.Column="1" 
                                       Foreground="White"
                                       FontWeight="Black" 
                                       FontSize="16"
                                       HorizontalAlignment="Center"/>

                            <!--Max(15)-->
                            <TextBlock Text="15" 
                                       Grid.Column="2" 
                                       FontSize="11"
                                       Foreground="#80FFFFFF" 
                                       HorizontalAlignment="Right"/>
                        </Grid>

                    </StackPanel>
                </Border>


                <!--*****Size*****-->
                <Border Grid.Row="2" 
                        Margin="10,6,10,6" 
                        CornerRadius="10"
                        Background="#12FFFFFF" 
                        BorderBrush="#30FFFFFF" 
                        BorderThickness="0.5">

                    <!--Stack-->
                    <StackPanel Margin="16,10,16,10">
                        <!--title-->
                        <TextBlock Text="Feldgröße:" 
                                   FontSize="16" 
                                   FontWeight="Bold" 
                                   Foreground="White" 
                                   Margin="0,0,0,8"/>


                        <!--Slider-->
                        <Slider x:Name="sizeSlider" 
                                Minimum="8" 
                                Maximum="20" 
                                Value="10" 
                                TickFrequency="1" 
                                IsSnapToTickEnabled="True" 
                                ValueChanged="Size_interval" 
                                Height="22">
                            <!--Custom Sliderstyle-->
                            <Slider.Template>
                                <ControlTemplate TargetType="Slider">
                                    <Grid>
                                        <Track x:Name="PART_Track">
                                            <!--SliderBeforeBG-->
                                            <Track.DecreaseRepeatButton>
                                                <RepeatButton Command="Slider.DecreaseLarge">
                                                    <RepeatButton.Template>
                                                        <ControlTemplate>
                                                            <Border Background="#FF0000FF" CornerRadius="99" Height="5"/>
                                                        </ControlTemplate>
                                                    </RepeatButton.Template>
                                                </RepeatButton>
                                            </Track.DecreaseRepeatButton>

                                            <!--Indicator-->
                                            <Track.Thumb>
                                                <Thumb>
                                                    <Thumb.Template>
                                                        <ControlTemplate>
                                                            <Ellipse Width="16" Height="16"
                                                                     Fill="#FF0000FF"
                                                                     Stroke="White"
                                                                     StrokeThickness="2.5"/>
                                                        </ControlTemplate>
                                                    </Thumb.Template>
                                                </Thumb>
                                            </Track.Thumb>

                                            <!--SliderAfterBG-->
                                            <Track.IncreaseRepeatButton>
                                                <RepeatButton Command="Slider.IncreaseLarge">
                                                    <RepeatButton.Template>
                                                        <ControlTemplate>
                                                            <Border Background="#30FFFFFF" CornerRadius="99" Height="5"/>
                                                        </ControlTemplate>
                                                    </RepeatButton.Template>
                                                </RepeatButton>
                                            </Track.IncreaseRepeatButton>

                                        </Track>
                                    </Grid>
                                </ControlTemplate>
                            </Slider.Template>
                        </Slider>


                        <!--MinMaxIndicator-->
                        <Grid Margin="0,6,0,0">
                            <!--ColumnDefinitions-->
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition/>
                                <ColumnDefinition/>
                                <ColumnDefinition/>
                            </Grid.ColumnDefinitions>

                            <!--Min(8)-->
                            <TextBlock Text="8" 
                                       Grid.Column="0" 
                                       FontSize="11"
                                       Foreground="#80FFFFFF" 
                                       HorizontalAlignment="Left"/>

                            <!--Indicator-->
                            <TextBlock Text="{Binding ElementName=sizeSlider, Path=Value}"
                                       Grid.Column="1" 
                                       Foreground="White"
                                       FontWeight="Black" 
                                       FontSize="16"
                                       HorizontalAlignment="Center"/>

                            <!--Max(20)-->
                            <TextBlock Text="20" 
                                       Grid.Column="2" 
                                       FontSize="11"
                                       Foreground="#80FFFFFF" 
                                       HorizontalAlignment="Right"/>
                        </Grid>

                    </StackPanel>
                </Border>


                <!--*****Bones*****-->
                <Border Grid.Row="3" 
                        Margin="10,6,10,6" 
                        CornerRadius="10"
                        Background="#12FFFFFF" 
                        BorderBrush="#30FFFFFF" 
                        BorderThickness="0.5">

                    <!--Stack-->
                    <StackPanel Margin="16,10,16,10">
                        <!--title-->
                        <TextBlock Text="Knochenanzahl:" 
                                   FontSize="16" 
                                   FontWeight="Bold" 
                                   Foreground="White" 
                                   Margin="0,0,0,8"/>


                        <!--Slider-->
                        <Slider x:Name="boneSlider" 
                                Minimum="1" 
                                Maximum="30" 
                                Value="1" 
                                TickFrequency="1" 
                                IsSnapToTickEnabled="True" 
                                ValueChanged="bone_interval" 
                                Height="22">
                            <!--Custom Sliderstyle-->
                            <Slider.Template>
                                <ControlTemplate TargetType="Slider">
                                    <Grid>
                                        <Track x:Name="PART_Track">
                                            <!--SliderBeforeBG-->
                                            <Track.DecreaseRepeatButton>
                                                <RepeatButton Command="Slider.DecreaseLarge">
                                                    <RepeatButton.Template>
                                                        <ControlTemplate>
                                                            <Border Background="#FF0000FF" CornerRadius="99" Height="5"/>
                                                        </ControlTemplate>
                                                    </RepeatButton.Template>
                                                </RepeatButton>
                                            </Track.DecreaseRepeatButton>

                                            <!--Indicator-->
                                            <Track.Thumb>
                                                <Thumb>
                                                    <Thumb.Template>
                                                        <ControlTemplate>
                                                            <Ellipse Width="16" Height="16"
                                                                     Fill="#FF0000FF"
                                                                     Stroke="White"
                                                                     StrokeThickness="2.5"/>
                                                        </ControlTemplate>
                                                    </Thumb.Template>
                                                </Thumb>
                                            </Track.Thumb>

                                            <!--SliderAfterBG-->
                                            <Track.IncreaseRepeatButton>
                                                <RepeatButton Command="Slider.IncreaseLarge">
                                                    <RepeatButton.Template>
                                                        <ControlTemplate>
                                                            <Border Background="#30FFFFFF" CornerRadius="99" Height="5"/>
                                                        </ControlTemplate>
                                                    </RepeatButton.Template>
                                                </RepeatButton>
                                            </Track.IncreaseRepeatButton>

                                        </Track>
                                    </Grid>
                                </ControlTemplate>
                            </Slider.Template>
                        </Slider>


                        <!--MinMaxIndicator-->
                        <Grid Margin="0,6,0,0">
                            <!--ColumnDefinitions-->
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition/>
                                <ColumnDefinition/>
                                <ColumnDefinition/>
                            </Grid.ColumnDefinitions>

                            <!--Min(1)-->
                            <TextBlock Text="1" 
                                       Grid.Column="0" 
                                       FontSize="11"
                                       Foreground="#80FFFFFF" 
                                       HorizontalAlignment="Left"/>

                            <!--Indicator-->
                            <TextBlock Text="{Binding ElementName=boneSlider, Path=Value}"
                                       Grid.Column="1" 
                                       Foreground="White"
                                       FontWeight="Black" 
                                       FontSize="16"
                                       HorizontalAlignment="Center"/>

                            <!--Max(30)-->
                            <TextBlock Text="30" 
                                       Grid.Column="2" 
                                       FontSize="11"
                                       Foreground="#80FFFFFF" 
                                       HorizontalAlignment="Right"/>
                        </Grid>

                    </StackPanel>
                </Border>

            </Grid>
        </Grid>
    </Grid>
</Window>